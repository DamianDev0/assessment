# Backend URL for Server Components (server-side only, not exposed to browser)
API_URL=http://localhost:5050

# Default organization (tenant) for server-side requests
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

# Backend URL for client-side Axios (exposed to browser)
NEXT_PUBLIC_API_URL=http://localhost:5050

# Default organization (tenant) for client-side requests
NEXT_PUBLIC_ORG_ID=00000000-0000-0000-0000-000000000001

# Pre-filled customer ID in the Create Job form (any valid UUID)
NEXT_PUBLIC_DEFAULT_CUSTOMER_ID=00000000-0000-0000-0000-000000000002

# Geoapify key for address autocomplete (optional, free tier)
NEXT_PUBLIC_GEOAPIFY_KEY=your_key_here

# OpenTelemetry service name (set automatically in docker-compose)
# OTEL_SERVICE_NAME=jobtracker-frontend
